## Outreach pipeline (Apollo → Gmail SMTP)

# Apollo.io People Search — lead source for recruiter contacts.
# https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# Per-candidate Gmail app passwords. Format: {'<email>': <app-password>, ...}
# 1) Enable 2FA on the Google account
# 2) Generate an app password at https://myaccount.google.com/apppasswords
# 3) Paste here. Spaces in the password are fine — they're stripped on read.
CANDIDATES={'chenhanwu2006@gmail.com': xxxx-xxxx-xxxx-xxxx}

# Vercel Cron auth — long random string. Add the same value to Vercel env so
# the cron endpoint accepts only Vercel's pings.
CRON_SECRET=

# Which candidate email the daily cron sends for (defaults to chenhanwu2006@gmail.com)
OUTREACH_CANDIDATE_EMAIL=chenhanwu2006@gmail.com

# Comma-separated list of admin emails that can view /admin/outreach.
ADMIN_EMAILS=

# GitHub Models — per-recipient email personalization (optional but recommended).
# Create a fine-grained PAT with the `models:read` scope at
# https://github.com/settings/tokens?type=beta
# If unset, the daily cron falls back to the static template.
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
